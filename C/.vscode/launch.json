{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C Program",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",  // exe gerado na mesma pasta
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",        // pasta do arquivo .c
            "environment": [],
            "externalConsole": true,        // mostra somente a saída do programa
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "preLaunchTask": "build C Program",  // compila antes de depurar
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}